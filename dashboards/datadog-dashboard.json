{
  "title": "memory-leak-reloader",
  "description": "Monitoring for the memory-leak-reloader controller: monitored pods, breaches, rollouts, concurrency, profile captures, datasource health, and notifications.",
  "layout_type": "ordered",
  "reflow_type": "auto",
  "widgets": [
    {
      "definition": {
        "type": "note",
        "content": "memory-leak-reloader exposes Prometheus metrics scraped into Datadog with the `memreload_` prefix. Dry-run shows as `memreload_dryrun=1`.",
        "background_color": "blue",
        "font_size": "14",
        "text_align": "left"
      }
    },
    {
      "definition": {
        "title": "Monitored pods",
        "type": "query_value",
        "requests": [{ "q": "avg:memreload_pods_monitored{*}", "aggregator": "last" }]
      }
    },
    {
      "definition": {
        "title": "In-flight rollouts vs cap",
        "type": "timeseries",
        "requests": [
          { "q": "avg:memreload_inflight_rollouts{*}", "display_type": "bars" },
          { "q": "avg:memreload_global_cap{*}", "display_type": "line" }
        ]
      }
    },
    {
      "definition": {
        "title": "Threshold breaches by mode",
        "type": "timeseries",
        "requests": [{ "q": "sum:memreload_threshold_breaches_total{*} by {mode}.as_count()", "display_type": "bars" }]
      }
    },
    {
      "definition": {
        "title": "Rollouts triggered by kind/result",
        "type": "timeseries",
        "requests": [{ "q": "sum:memreload_rollouts_triggered_total{*} by {workload_kind,result}.as_count()", "display_type": "bars" }]
      }
    },
    {
      "definition": {
        "title": "Rollouts skipped by reason",
        "type": "timeseries",
        "requests": [{ "q": "sum:memreload_rollouts_skipped_total{*} by {reason}.as_count()", "display_type": "bars" }]
      }
    },
    {
      "definition": {
        "title": "Rollouts deferred (maintenance window)",
        "type": "timeseries",
        "requests": [{ "q": "sum:memreload_rollouts_deferred_total{*}.as_count()", "display_type": "bars" }]
      }
    },
    {
      "definition": {
        "title": "Sample buffer series (cardinality)",
        "type": "timeseries",
        "requests": [{ "q": "avg:memreload_sample_buffer_series{*}", "display_type": "line" }]
      }
    },
    {
      "definition": {
        "title": "Containers ignored (no limit)",
        "type": "timeseries",
        "requests": [{ "q": "avg:memreload_containers_ignored{*} by {reason}", "display_type": "line" }]
      }
    },
    {
      "definition": {
        "title": "Datasource errors",
        "type": "timeseries",
        "requests": [{ "q": "sum:memreload_datasource_errors_total{*} by {source}.as_count()", "display_type": "bars" }]
      }
    },
    {
      "definition": {
        "title": "Profile captures by result",
        "type": "timeseries",
        "requests": [{ "q": "sum:memreload_profile_captures_total{*} by {result}.as_count()", "display_type": "bars" }]
      }
    },
    {
      "definition": {
        "title": "Notifications by sink/result",
        "type": "timeseries",
        "requests": [{ "q": "sum:memreload_notifications_total{*} by {sink,result}.as_count()", "display_type": "bars" }]
      }
    }
  ]
}
